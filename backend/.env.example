APP_ENV=dev

# Server-only database settings.
# Prefer DATABASE_URL for cloud deployments. Never expose this value to the
# frontend and never prefix it with NEXT_PUBLIC_.
# DATABASE_URL=postgresql+psycopg://<user>:<password>@<host>:<port>/<database>
DATABASE_CONNECT_TIMEOUT_SECONDS=5
DATABASE_STATEMENT_TIMEOUT_MS=3000

POSTGRES_HOST=localhost
POSTGRES_PORT=5433
POSTGRES_DB=cfs_dev
POSTGRES_USER=postgres

# Prefer POSTGRES_PASSWORD for the API.
# Local development may also rely on CFS_POSTGRES_PASSWORD already set in Windows.
POSTGRES_PASSWORD=

SQLALCHEMY_ECHO=false

# Optional backend-only Ask CFS provider settings. Leave disabled for the
# deterministic local fallback. Real local keys belong in ../backend.env,
# never in frontend env or Vercel demo env.
CFS_AI_ENABLED=false
CFS_AI_PROVIDER=none
CFS_AI_MODEL=
OPENAI_API_KEY=

# Comma-separated local frontend origins that may call the API in development.
# Production should use explicit deployment origins only.
# Example production value:
# CORS_ALLOWED_ORIGINS=https://<vercel-project>.vercel.app,https://<custom-domain>
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:3001,http://127.0.0.1:3001,http://localhost:3003,http://127.0.0.1:3003
