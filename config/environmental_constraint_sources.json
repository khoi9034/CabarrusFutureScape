  },
  "source_priority_rules": [
    "Use OpenData/Hydrology/MapServer/0 as the primary hydrology source.",
    "Use OpenData/Flood_Hazard_Areas/MapServer/0, /1, and /2 as primary local flood reference sources.",
    "Keep legacy opendata/MapServer/25, /26, /28, /29, and /30 as fallback/reference only.",
    "Keep opendata/MapServer/27 for soils unless a newer soils service is found.",
    "Keep opendata/MapServer/143 for Water Supply Watershed unless a newer watershed service is found.",
    "FEMA NFHL remains authoritative for regulatory flood constraints."
