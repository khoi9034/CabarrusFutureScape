# Frontend-only public settings.
# These values are bundled into the browser. Do not put secrets here.

# Local development:
NEXT_PUBLIC_USE_BACKEND_API=true
NEXT_PUBLIC_CFS_API_BASE_URL=http://127.0.0.1:8000

# Production example:
# NEXT_PUBLIC_USE_BACKEND_API=true
# NEXT_PUBLIC_CFS_API_BASE_URL=https://<render-backend-service>.onrender.com
